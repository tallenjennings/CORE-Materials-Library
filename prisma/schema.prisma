generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql" url = env("DATABASE_URL") }

enum UserRole { STAFF SUPERVISOR ADMIN }
enum PlacementType { CELL STORAGE IN_TRANSFER UNLOCATED RETIRED }
enum BinCondition { GOOD NEEDS_RESTOCKING MISSING_ITEMS PARTIALLY_DAMAGED UNUSABLE MISSING RETIRED }
enum OperationalStatus { AVAILABLE REQUESTED APPROVED_FOR_TRANSFER IN_TRANSFER IN_USE UNLOCATED RETIRED }
enum AssignmentType { PRIMARY SUPPORTING TEMPORARY }
enum RequestStatus { REQUESTED APPROVED IN_TRANSFER ARRIVED DECLINED CANCELLED }
enum TransferStatus { APPROVED IN_TRANSFER ARRIVED CANCELLED }
enum IssueType { MISSING_ITEMS DAMAGED_ITEMS BIN_CONTAINER_DAMAGED LABEL_DAMAGED CLEANING_REQUIRED NEEDS_RESTOCKING BIN_MISSING OTHER }
enum IssueStatus { OPEN UNDER_REVIEW RESOLVED CLOSED_WITHOUT_ACTION }
enum Severity { LOW MEDIUM HIGH UNUSABLE }
enum InventoryScope { LOCATION QUADRANT STORAGE_AREA }
enum NotificationType { REQUEST_SUBMITTED REQUEST_APPROVED REQUEST_DECLINED TRANSFER_READY TRANSFER_STARTED ARRIVAL_WAITING ISSUE_SUBMITTED ISSUE_RESOLVED }

model User { id String @id @default(cuid()) name String email String @unique passwordHash String role UserRole @default(STAFF) active Boolean @default(true) homeLocationId String? homeLocation Location? @relation(fields:[homeLocationId],references:[id]) createdAt DateTime @default(now()) updatedAt DateTime @updatedAt lastLoginAt DateTime? resetTokens PasswordResetToken[] sessions Session[] createdBins Bin[] @relation("CreatedBins") updatedBins Bin[] @relation("UpdatedBins") assignments QuadrantAssignment[] reportedIssues BinIssue[] notifications Notification[] }
model Session { id String @id @default(cuid()) tokenHash String @unique userId String user User @relation(fields:[userId],references:[id],onDelete:Cascade) expiresAt DateTime createdAt DateTime @default(now()) ipAddress String? userAgent String? }
model PasswordResetToken { id String @id @default(cuid()) tokenHash String @unique userId String user User @relation(fields:[userId],references:[id],onDelete:Cascade) expiresAt DateTime usedAt DateTime? createdAt DateTime @default(now()) }
model Location { id String @id @default(cuid()) name String @unique slug String @unique description String? sortOrder Int @default(0) active Boolean @default(true) createdAt DateTime @default(now()) updatedAt DateTime @updatedAt quadrants Quadrant[] storageAreas StorageArea[] users User[] }
model Quadrant { id String @id @default(cuid()) locationId String location Location @relation(fields:[locationId],references:[id]) name String displayName String? sortOrder Int @default(0) active Boolean @default(true) createdAt DateTime @default(now()) updatedAt DateTime @updatedAt cells Cell[] assignments QuadrantAssignment[] @@unique([locationId,name]) }
model Cell { id String @id @default(cuid()) quadrantId String quadrant Quadrant @relation(fields:[quadrantId],references:[id],onDelete:Cascade) identifier String displayName String? notes String? instructions String? sortOrder Int @default(0) active Boolean @default(true) placements BinPlacement[] @@unique([quadrantId,identifier]) }
model StorageArea { id String @id @default(cuid()) locationId String location Location @relation(fields:[locationId],references:[id]) name String description String? notes String? sortOrder Int @default(0) active Boolean @default(true) placements BinPlacement[] @@unique([locationId,name]) }
model BinCategory { id String @id @default(cuid()) name String @unique description String? active Boolean @default(true) bins Bin[] }
model UploadedFile { id String @id @default(cuid()) storageKey String @unique originalName String mimeType String byteSize Int url String? createdAt DateTime @default(now()) bins Bin[] issues BinIssue[] }
model Bin { id String @id @default(cuid()) binNumber Int @unique name String contentsDescription String detailedInventory String? categoryId String? category BinCategory? @relation(fields:[categoryId],references:[id]) recommendedAgeRange String? childrenSupported Int? photoId String? photo UploadedFile? @relation(fields:[photoId],references:[id]) condition BinCondition @default(GOOD) operationalStatus OperationalStatus @default(AVAILABLE) replacementCost Decimal? notes String? active Boolean @default(true) retiredAt DateTime? lastInventoriedAt DateTime? createdAt DateTime @default(now()) updatedAt DateTime @updatedAt createdById String? createdBy User? @relation("CreatedBins",fields:[createdById],references:[id]) updatedById String? updatedBy User? @relation("UpdatedBins",fields:[updatedById],references:[id]) placements BinPlacement[] requests BinRequest[] transfers BinTransfer[] issues BinIssue[] checks InventoryCheckItem[] }
model BinPlacement { id String @id @default(cuid()) binId String bin Bin @relation(fields:[binId],references:[id]) type PlacementType cellId String? cell Cell? @relation(fields:[cellId],references:[id]) storageAreaId String? storageArea StorageArea? @relation(fields:[storageAreaId],references:[id]) active Boolean @default(true) activePlacementKey String? @unique notes String? placedAt DateTime @default(now()) endedAt DateTime? createdById String? @@index([binId, active]) }
model QuadrantAssignment { id String @id @default(cuid()) userId String user User @relation(fields:[userId],references:[id]) locationId String quadrantId String quadrant Quadrant @relation(fields:[quadrantId],references:[id]) startDate DateTime endDate DateTime? type AssignmentType active Boolean @default(true) notes String? createdById String? createdAt DateTime @default(now()) }
model BinRequest { id String @id @default(cuid()) binId String bin Bin @relation(fields:[binId],references:[id]) requestedById String requestedBy User? @relation(fields:[requestedById],references:[id]) destinationLocationId String? destinationQuadrantId String? destinationStorageAreaId String? requestedDate DateTime? reason String? status RequestStatus @default(REQUESTED) approvedById String? approvedAt DateTime? approvalNotes String? declinedById String? declinedAt DateTime? declineReason String? cancelledById String? cancelledAt DateTime? createdAt DateTime @default(now()) updatedAt DateTime @updatedAt transfer BinTransfer? }
model BinTransfer { id String @id @default(cuid()) binId String bin Bin @relation(fields:[binId],references:[id]) requestId String? @unique request BinRequest? @relation(fields:[requestId],references:[id]) status TransferStatus @default(APPROVED) sourceSnapshot Json destinationSnapshot Json startedById String? startedAt DateTime? transporterName String? receivedById String? arrivedAt DateTime? arrivalNotes String? createdAt DateTime @default(now()) updatedAt DateTime @updatedAt }
model BinIssue { id String @id @default(cuid()) binId String bin Bin @relation(fields:[binId],references:[id]) type IssueType description String photoId String? photo UploadedFile? @relation(fields:[photoId],references:[id]) severity Severity status IssueStatus @default(OPEN) usable Boolean @default(true) placementSnapshot Json? reportedById String reportedBy User @relation(fields:[reportedById],references:[id]) reportedAt DateTime @default(now()) resolutionNotes String? resolvedById String? resolvedAt DateTime? }
model InventoryCheck { id String @id @default(cuid()) scope InventoryScope locationId String? quadrantId String? storageAreaId String? completedById String completedAt DateTime? notes String? discrepancies Json? createdAt DateTime @default(now()) items InventoryCheckItem[] }
model InventoryCheckItem { id String @id @default(cuid()) checkId String check InventoryCheck @relation(fields:[checkId],references:[id],onDelete:Cascade) binId String bin Bin @relation(fields:[binId],references:[id]) expected Boolean @default(true) confirmed Boolean @default(false) missing Boolean @default(false) moved Boolean @default(false) notes String? }
model AuditLog { id String @id @default(cuid()) userId String? action String entityType String entityId String? previousValues Json? newValues Json? ipAddress String? createdAt DateTime @default(now()) }
model BinHistory { id String @id @default(cuid()) binId String action String summary String? previousValues Json? newValues Json? createdById String? createdAt DateTime @default(now()) }
model Notification { id String @id @default(cuid()) userId String user User @relation(fields:[userId],references:[id],onDelete:Cascade) type NotificationType title String body String? readAt DateTime? createdAt DateTime @default(now()) }
model AppSetting { id String @id @default(cuid()) key String @unique value Json updatedAt DateTime @updatedAt }
